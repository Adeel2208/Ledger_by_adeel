# ── LLM (OpenAI by default) ───────────────────────────────────
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...         # only if LLM_PROVIDER=anthropic
LLM_MODEL=gpt-5.6-terra                # reasoning/memo. gpt-5.6-sol = frontier, gpt-5.6-terra = balanced
LLM_MODEL_FAST=gpt-5.6-luna            # extraction/screening (cheap, high-volume)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1536

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite:///./vcbrain.db    # prod: postgresql+psycopg://vcbrain:vcbrain@db:5432/vcbrain

# ── Vector store ──────────────────────────────────────────────
VECTOR_BACKEND=chroma                  # chroma (dev) | pgvector (prod)
CHROMA_DIR=./.chroma

# ── Ingestion / outbound sourcing ─────────────────────────────
GITHUB_TOKEN=                          # optional; raises rate limits for outbound GitHub scan
TAVILY_API_KEY=                        # optional; enables real web enrichment + validator agent
OUTBOUND_SCAN_INTERVAL_MIN=60          # APScheduler interval for the outbound scan

# ── App ───────────────────────────────────────────────────────
APP_ENV=dev                            # dev | prod
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173
